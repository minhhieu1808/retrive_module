# LLM API Settings (Custom/Local Server)
LLM_API_BASE=http://localhost:4000/v1
LLM_API_KEY=your_authorization_token_here
LLM_MODEL=google/gemma-4-31b-it

# FastAPI Settings
HOST=127.0.0.1
PORT=8000

# Gemini API Settings (Optional, needed if you use Gemini Multimodal Embeddings)
GEMINI_API_KEY=your_gemini_api_key_here

# Elasticsearch Settings (HTTPS + User/Password Authentication)
ELASTICSEARCH_URL=http://171.232.252.198:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=your_secure_password_here
